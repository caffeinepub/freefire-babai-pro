@import url("https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap");
@import url("https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap");

@font-face {
  font-family: "Bricolage Grotesque";
  src: url("/assets/fonts/BricolageGrotesque.woff2") format("woff2");
  font-weight: 200 800;
  font-display: swap;
}
@font-face {
  font-family: "Figtree";
  src: url("/assets/fonts/Figtree.woff2") format("woff2");
  font-weight: 300 900;
  font-display: swap;
}

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 0.08 0.02 245;
    --foreground: 0.94 0.01 245;
    --card: 0.12 0.04 245;
    --card-foreground: 0.94 0.01 245;
    --primary: 0.65 0.22 42;
    --primary-foreground: 0.06 0.01 245;
    --secondary: 0.16 0.05 250;
    --secondary-foreground: 0.88 0.01 245;
    --muted: 0.16 0.03 250;
    --muted-foreground: 0.55 0.04 250;
    --accent: 0.55 0.2 42;
    --accent-foreground: 0.06 0.01 245;
    --destructive: 0.55 0.26 22;
    --destructive-foreground: 0.98 0 0;
    --border: 0.22 0.06 245;
    --input: 0.16 0.04 250;
    --ring: 0.65 0.22 42;
    --radius: 0.75rem;
  }
}

*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html,
body {
  height: 100%;
  background: #0a0a1a;
  color: #ffffff;
  font-family: "Rajdhani", "Orbitron", system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

#root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

button {
  cursor: pointer;
  font-family: inherit;
  border: none;
  background: none;
}
input {
  font-family: inherit;
}
a {
  color: inherit;
  text-decoration: none;
}

/* ================================================================
   CSS VARIABLES
   ================================================================ */
:root {
  --orange: #ff6b00;
  --orange-dark: #cc5500;
  --orange-glow: rgba(255, 107, 0, 0.4);
  --navy: #0a0a1a;
  --navy-card: rgba(255, 255, 255, 0.05);
  --navy-border: rgba(255, 107, 0, 0.3);
  --green-cta: #00c864;
  --muted: rgba(255, 255, 255, 0.5);
}

/* ================================================================
   KEYFRAMES
   ================================================================ */
@keyframes dhurandar3d {
  0% {
    transform: perspective(400px) rotateY(0deg) scale(1);
    text-shadow: 0 0 12px #ff6b00, 0 0 30px rgba(255, 107, 0, 0.5);
  }
  25% {
    transform: perspective(400px) rotateY(15deg) scale(1.03);
    text-shadow: 0 0 20px #ff6b00, 0 0 50px rgba(255, 107, 0, 0.7), 4px 0 8px
      rgba(255, 200, 0, 0.4);
  }
  50% {
    transform: perspective(400px) rotateY(0deg) scale(1.05);
    text-shadow: 0 0 25px #ff9500, 0 0 60px rgba(255, 150, 0, 0.8);
  }
  75% {
    transform: perspective(400px) rotateY(-15deg) scale(1.03);
    text-shadow: 0 0 20px #ff6b00, 0 0 50px rgba(255, 107, 0, 0.7), -4px 0 8px
      rgba(255, 200, 0, 0.4);
  }
  100% {
    transform: perspective(400px) rotateY(0deg) scale(1);
    text-shadow: 0 0 12px #ff6b00, 0 0 30px rgba(255, 107, 0, 0.5);
  }
}

@keyframes spinLoader {
  to {
    transform: rotate(360deg);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse-glow {
  0%,
  100% {
    box-shadow: 0 0 10px var(--orange-glow);
  }
  50% {
    box-shadow: 0 0 25px var(--orange-glow), 0 0 50px rgba(255, 107, 0, 0.3);
  }
}

@keyframes bounce-in {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  70% {
    transform: scale(1.08);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes livePulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.4;
  }
}

/* ================================================================
   APP STRUCTURE
   ================================================================ */
.app-container {
  width: 100%;
  max-width: 480px;
  margin: 0 auto;
  min-height: 100vh;
  background: var(--navy);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.app-header {
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 480px;
  z-index: 50;
  background: linear-gradient(
    180deg,
    rgba(10, 10, 26, 0.98) 0%,
    rgba(10, 10, 26, 0.85) 100%
  );
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255, 107, 0, 0.2);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.app-title {
  font-family: "Orbitron", sans-serif;
  font-size: 1rem;
  font-weight: 900;
  background: linear-gradient(135deg, #ff6b00, #ffaa00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 0.05em;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.icon-btn {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: rgba(255, 107, 0, 0.12);
  border: 1px solid rgba(255, 107, 0, 0.25);
  color: #ff6b00;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  position: relative;
  transition: all 0.2s;
}

.icon-btn:hover {
  background: rgba(255, 107, 0, 0.25);
}

.online-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #00c864;
  box-shadow: 0 0 6px #00c864;
  animation: livePulse 2s infinite;
}

.offline-dot {
  background: #ef4444;
  box-shadow: 0 0 6px #ef4444;
}

.player-count {
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.6);
  font-family: "Rajdhani", sans-serif;
}

.notification-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: #ef4444;
  color: white;
  border-radius: 50%;
  width: 16px;
  height: 16px;
  font-size: 0.6rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Rajdhani", sans-serif;
}

/* ================================================================
   LOADING
   ================================================================ */
.loading-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(10, 10, 26, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.spinner {
  width: 36px;
  height: 36px;
  border: 3px solid rgba(255, 107, 0, 0.2);
  border-top-color: #ff6b00;
  border-radius: 50%;
  animation: spinLoader 0.8s linear infinite;
}

/* ================================================================
   SPLASH
   ================================================================ */
.splash-screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32px;
  background: radial-gradient(
      ellipse at center,
      rgba(255, 107, 0, 0.08) 0%,
      transparent 60%
    ), #0a0a1a;
}

/* ================================================================
   AUTH PAGES
   ================================================================ */
.auth-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 40px 20px 100px;
  overflow-y: auto;
  position: relative;
  background: #0a0a1a;
}

.dhurandar-title {
  font-family: "Orbitron", sans-serif;
  font-size: 28px;
  font-weight: 900;
  letter-spacing: 0.08em;
  color: #ff6b00;
  text-transform: uppercase;
  animation: dhurandar3d 3s ease-in-out infinite;
  margin-bottom: 4px;
  display: block;
  text-align: center;
}

.dhurandar-tagline {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  letter-spacing: 0.05em;
  margin-bottom: 20px;
  font-family: "Rajdhani", sans-serif;
}

.auth-logo {
  font-family: "Orbitron", sans-serif;
  font-size: 1.3rem;
  font-weight: 900;
  color: #ff6b00;
  text-align: center;
  margin-bottom: 8px;
}

.auth-subtitle {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  margin-bottom: 20px;
  font-family: "Rajdhani", sans-serif;
}

.auth-form {
  width: 100%;
  max-width: 380px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 107, 0, 0.2);
  border-radius: 16px;
  padding: 24px 20px;
  backdrop-filter: blur(8px);
}

.create-account-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 14px 20px;
  background: linear-gradient(135deg, #00c864, #00a050);
  color: white;
  font-family: "Orbitron", sans-serif;
  font-size: 0.75rem;
  font-weight: 900;
  border-radius: 12px;
  letter-spacing: 0.05em;
  cursor: pointer;
  border: none;
  box-shadow: 0 4px 20px rgba(0, 200, 100, 0.4);
  transition: all 0.25s;
  text-transform: uppercase;
}

.create-account-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(0, 200, 100, 0.5);
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.field-label {
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.5);
  font-family: "Rajdhani", sans-serif;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.fire-input {
  width: 100%;
  padding: 12px 14px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 107, 0, 0.3);
  border-radius: 10px;
  color: white;
  font-size: 0.95rem;
  outline: none;
  transition: all 0.2s;
  font-family: "Rajdhani", sans-serif;
}

.fire-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.fire-input:focus {
  border-color: #ff6b00;
  box-shadow: 0 0 0 3px rgba(255, 107, 0, 0.2);
  background: rgba(255, 107, 0, 0.08);
}

.fire-btn {
  width: 100%;
  padding: 13px;
  background: linear-gradient(135deg, #ff6b00, #cc5500);
  color: white;
  font-family: "Orbitron", sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  box-shadow: 0 4px 16px rgba(255, 107, 0, 0.4);
  transition: all 0.2s;
}

.fire-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(255, 107, 0, 0.5);
}

.fire-btn:active {
  transform: translateY(0);
}

.fire-btn-secondary {
  background: rgba(255, 107, 0, 0.15);
  border: 1px solid rgba(255, 107, 0, 0.4);
  color: #ff6b00;
  box-shadow: none;
}

.fire-btn-secondary:hover {
  background: rgba(255, 107, 0, 0.25);
}

.fire-btn-danger {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  box-shadow: 0 4px 16px rgba(239, 68, 68, 0.4);
}

.fire-btn-success {
  background: linear-gradient(135deg, #00c864, #00a050);
  box-shadow: 0 4px 16px rgba(0, 200, 100, 0.4);
}

.auth-link {
  color: rgba(255, 255, 255, 0.5);
  font-size: 0.82rem;
  text-decoration: underline;
  cursor: pointer;
  background: none;
  border: none;
  font-family: "Rajdhani", sans-serif;
  transition: color 0.2s;
}

.auth-link:hover {
  color: #ff6b00;
}

/* ================================================================
   BOTTOM NAV
   ================================================================ */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 480px;
  z-index: 50;
  background: linear-gradient(0deg, #0d0d1f 0%, rgba(13, 13, 31, 0.95) 100%);
  border-top: 1px solid rgba(255, 107, 0, 0.2);
  display: flex;
  padding: 6px 0 env(safe-area-inset-bottom, 6px);
  backdrop-filter: blur(16px);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 6px 4px;
  color: rgba(255, 255, 255, 0.35);
  font-size: 0.62rem;
  font-family: "Rajdhani", sans-serif;
  letter-spacing: 0.03em;
  cursor: pointer;
  background: none;
  border: none;
  transition: all 0.2s;
  position: relative;
}

.nav-item.active {
  color: #ff6b00;
}

.nav-item.active::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28px;
  height: 2px;
  background: #ff6b00;
  border-radius: 0 0 4px 4px;
  box-shadow: 0 0 8px #ff6b00;
}

/* ================================================================
   VIEW CONTAINERS
   ================================================================ */
.view-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 58px 12px 80px;
  -webkit-overflow-scrolling: touch;
}

.view-title {
  font-family: "Orbitron", sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: #ff6b00;
  margin-bottom: 16px;
  letter-spacing: 0.05em;
}

.section-label {
  font-family: "Orbitron", sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  color: #ff6b00;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
}

/* ================================================================
   CARDS
   ================================================================ */
.card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 107, 0, 0.25);
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 12px;
}

.card-glow {
  box-shadow: 0 0 20px rgba(255, 107, 0, 0.15), inset 0 1px 0
    rgba(255, 255, 255, 0.05);
}

/* ================================================================
   MODE CARDS
   ================================================================ */
.mode-card {
  position: relative;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 107, 0, 0.25);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 10px;
  cursor: pointer;
  transition: all 0.25s;
}

.mode-card:hover {
  border-color: rgba(255, 107, 0, 0.6);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(255, 107, 0, 0.2);
}

.mode-poster {
  width: 100%;
  height: 110px;
  object-fit: cover;
  display: block;
}

.mode-poster-fallback {
  width: 100%;
  height: 110px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  background: linear-gradient(
    135deg,
    rgba(255, 107, 0, 0.15),
    rgba(10, 10, 26, 0.8)
  );
}

.mode-info {
  padding: 10px 14px 12px;
}

.mode-title {
  font-family: "Orbitron", sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: white;
  margin-bottom: 4px;
}

.mode-desc {
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.5);
  font-family: "Rajdhani", sans-serif;
}

.mode-meta {
  display: flex;
  gap: 8px;
  margin-top: 8px;
  flex-wrap: wrap;
}

.meta-chip {
  font-size: 0.7rem;
  padding: 3px 8px;
  border-radius: 20px;
  background: rgba(255, 107, 0, 0.12);
  border: 1px solid rgba(255, 107, 0, 0.3);
  color: #ff6b00;
  font-family: "Rajdhani", sans-serif;
  font-weight: 600;
}

.join-btn {
  float: right;
  margin-top: -4px;
  padding: 7px 16px;
  background: linear-gradient(135deg, #ff6b00, #cc5500);
  color: white;
  font-family: "Orbitron", sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  letter-spacing: 0.05em;
  box-shadow: 0 2px 10px rgba(255, 107, 0, 0.4);
  transition: all 0.2s;
}

.join-btn:hover {
  transform: scale(1.05);
}

/* ================================================================
   MODALS
   ================================================================ */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.modal-sheet {
  width: 100%;
  max-width: 480px;
  background: linear-gradient(180deg, #111122 0%, #0a0a1a 100%);
  border: 1px solid rgba(255, 107, 0, 0.3);
  border-radius: 24px 24px 0 0;
  padding: 24px 20px 32px;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-handle {
  width: 40px;
  height: 4px;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 2px;
  margin: 0 auto 20px;
}

.modal-title {
  font-family: "Orbitron", sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: #ff6b00;
  margin-bottom: 16px;
  text-align: center;
}

/* ================================================================
   HERO BANNER
   ================================================================ */
.hero-banner {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 16px;
  min-height: 120px;
  background: linear-gradient(135deg, #1a0a00, #2d1000, #1a0500);
  display: flex;
  align-items: center;
  padding: 20px;
  border: 1px solid rgba(255, 107, 0, 0.3);
}

.hero-banner-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.4;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  font-family: "Orbitron", sans-serif;
  font-size: 1.1rem;
  font-weight: 900;
  background: linear-gradient(135deg, #ff6b00, #ffaa00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 4px;
  letter-spacing: 0.05em;
}

.hero-subtitle {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.6);
  font-family: "Rajdhani", sans-serif;
}

.live-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(239, 68, 68, 0.2);
  border: 1px solid rgba(239, 68, 68, 0.5);
  color: #ef4444;
  font-size: 0.65rem;
  font-family: "Orbitron", sans-serif;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 20px;
  letter-spacing: 0.05em;
}

.live-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #ef4444;
  animation: livePulse 1s infinite;
}

/* ================================================================
   UPI INFO BOX
   ================================================================ */
.upi-box {
  background: linear-gradient(135deg, #0e1420, #121929, #0d1a3a);
  border: 2px solid #ff6b00;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 14px;
  box-shadow: 0 0 20px rgba(255, 107, 0, 0.2), inset 0 1px 0
    rgba(255, 255, 255, 0.05);
  animation: pulse-glow 3s ease-in-out infinite;
}

.upi-label {
  font-family: "Orbitron", sans-serif;
  font-size: 0.65rem;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.upi-value {
  font-family: "Orbitron", sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  color: #ff6b00;
  word-break: break-all;
}

.copy-btn {
  padding: 4px 10px;
  background: rgba(255, 107, 0, 0.15);
  border: 1px solid rgba(255, 107, 0, 0.3);
  border-radius: 6px;
  color: #ff6b00;
  font-size: 0.7rem;
  cursor: pointer;
  font-family: "Rajdhani", sans-serif;
  font-weight: 600;
  transition: all 0.2s;
  white-space: nowrap;
}

.copy-btn:hover {
  background: rgba(255, 107, 0, 0.25);
}

.wa-btn {
  padding: 4px 10px;
  background: rgba(0, 200, 100, 0.15);
  border: 1px solid rgba(0, 200, 100, 0.3);
  border-radius: 6px;
  color: #00c864;
  font-size: 0.7rem;
  cursor: pointer;
  font-family: "Rajdhani", sans-serif;
  font-weight: 600;
  transition: all 0.2s;
}

.wa-btn:hover {
  background: rgba(0, 200, 100, 0.25);
}

/* ================================================================
   SCHEDULE
   ================================================================ */
.schedule-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border-radius: 8px;
  margin-bottom: 4px;
  font-family: "Rajdhani", sans-serif;
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.03);
  transition: all 0.2s;
}

.schedule-item.live-slot {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: white;
}

.schedule-time {
  font-family: "Orbitron", sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  color: #ff6b00;
  min-width: 52px;
}

/* ================================================================
   LEADERBOARD
   ================================================================ */
.rank-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 107, 0, 0.2);
  border-radius: 12px;
  margin-bottom: 8px;
  transition: all 0.2s;
}

.rank-card.top-1 {
  background: linear-gradient(
    135deg,
    rgba(255, 215, 0, 0.08),
    rgba(255, 107, 0, 0.05)
  );
  border-color: rgba(255, 215, 0, 0.4);
}

.rank-card.top-2 {
  background: linear-gradient(
    135deg,
    rgba(192, 192, 192, 0.08),
    rgba(255, 107, 0, 0.03)
  );
  border-color: rgba(192, 192, 192, 0.3);
}

.rank-card.top-3 {
  background: linear-gradient(
    135deg,
    rgba(205, 127, 50, 0.08),
    rgba(255, 107, 0, 0.03)
  );
  border-color: rgba(205, 127, 50, 0.3);
}

.rank-badge {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Orbitron", sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  flex-shrink: 0;
}

.rank-1 {
  background: linear-gradient(135deg, #ffd700, #ff9500);
  color: #000;
}
.rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #a0a0a0);
  color: #000;
}
.rank-3 {
  background: linear-gradient(135deg, #cd7f32, #a0522d);
  color: white;
}
.rank-other {
  background: rgba(255, 107, 0, 0.1);
  border: 1px solid rgba(255, 107, 0, 0.3);
  color: #ff6b00;
}

.rank-name {
  font-family: "Rajdhani", sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  color: white;
  flex: 1;
}

.rank-uid {
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.4);
  font-family: "Rajdhani", sans-serif;
}

.rank-coins {
  font-family: "Orbitron", sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: #ff6b00;
}

/* ================================================================
   PROFILE
   ================================================================ */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 16px;
  background: linear-gradient(
    135deg,
    rgba(255, 107, 0, 0.08),
    rgba(10, 10, 26, 0.95)
  );
  border: 1px solid rgba(255, 107, 0, 0.25);
  border-radius: 16px;
  margin-bottom: 14px;
}

.avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Orbitron", sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
  margin-bottom: 10px;
  border: 3px solid rgba(255, 107, 0, 0.5);
  box-shadow: 0 0 20px rgba(255, 107, 0, 0.3);
  text-shadow: 0 0 8px rgba(0, 0, 0, 0.5);
}

.profile-name {
  font-family: "Orbitron", sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: white;
  margin-bottom: 4px;
}

.profile-uid {
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.4);
  font-family: "Rajdhani", sans-serif;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-bottom: 14px;
}

.stat-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 107, 0, 0.2);
  border-radius: 12px;
  padding: 12px 8px;
  text-align: center;
}

.stat-value {
  font-family: "Orbitron", sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: #ff6b00;
}

.stat-label {
  font-size: 0.65rem;
  color: rgba(255, 255, 255, 0.4);
  font-family: "Rajdhani", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 2px;
}

/* ================================================================
   ADMIN
   ================================================================ */
.admin-panel {
  min-height: 100vh;
  background: #0a0a1a;
  overflow-y: auto;
}

.admin-header {
  background: linear-gradient(
    135deg,
    rgba(255, 107, 0, 0.15),
    rgba(10, 10, 26, 0.95)
  );
  border-bottom: 2px solid #ff6b00;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  position: sticky;
  top: 0;
  z-index: 50;
}

.admin-title {
  font-family: "Orbitron", sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: #ff6b00;
  flex: 1;
  letter-spacing: 0.05em;
}

.admin-nav {
  display: flex;
  gap: 6px;
  padding: 12px 14px;
  overflow-x: auto;
  border-bottom: 1px solid rgba(255, 107, 0, 0.15);
  -webkit-overflow-scrolling: touch;
}

.admin-nav::-webkit-scrollbar {
  display: none;
}

.admin-tab {
  white-space: nowrap;
  padding: 7px 14px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 107, 0, 0.2);
  border-radius: 20px;
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.75rem;
  font-family: "Rajdhani", sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
}

.admin-tab.active {
  background: rgba(255, 107, 0, 0.2);
  border-color: #ff6b00;
  color: #ff6b00;
}

.admin-content {
  padding: 14px;
}

.admin-input {
  width: 100%;
  padding: 10px 12px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 107, 0, 0.25);
  border-radius: 8px;
  color: white;
  font-size: 0.9rem;
  font-family: "Rajdhani", sans-serif;
  outline: none;
  margin-bottom: 8px;
  transition: all 0.2s;
}

.admin-input:focus {
  border-color: #ff6b00;
  background: rgba(255, 107, 0, 0.06);
}

.admin-select {
  width: 100%;
  padding: 10px 12px;
  background: #111122;
  border: 1px solid rgba(255, 107, 0, 0.25);
  border-radius: 8px;
  color: white;
  font-size: 0.9rem;
  font-family: "Rajdhani", sans-serif;
  outline: none;
  margin-bottom: 8px;
  cursor: pointer;
}

.admin-select option {
  background: #111122;
}

.match-admin-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 107, 0, 0.2);
  border-radius: 12px;
  padding: 12px 14px;
  margin-bottom: 10px;
}

.user-admin-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 107, 0, 0.15);
  border-radius: 10px;
  padding: 10px 14px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: all 0.2s;
}

.user-admin-card:hover {
  border-color: rgba(255, 107, 0, 0.4);
}

.status-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 20px;
  font-size: 0.65rem;
  font-family: "Rajdhani", sans-serif;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.status-pending {
  background: rgba(234, 179, 8, 0.15);
  border: 1px solid rgba(234, 179, 8, 0.4);
  color: #eab308;
}
.status-approved {
  background: rgba(0, 200, 100, 0.15);
  border: 1px solid rgba(0, 200, 100, 0.4);
  color: #00c864;
}
.status-rejected {
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.4);
  color: #ef4444;
}
.status-live {
  background: rgba(255, 107, 0, 0.15);
  border: 1px solid rgba(255, 107, 0, 0.4);
  color: #ff6b00;
}
.status-waiting {
  background: rgba(99, 102, 241, 0.15);
  border: 1px solid rgba(99, 102, 241, 0.4);
  color: #818cf8;
}
.status-full {
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.4);
  color: #ef4444;
}
.status-completed {
  background: rgba(107, 114, 128, 0.15);
  border: 1px solid rgba(107, 114, 128, 0.4);
  color: #9ca3af;
}

/* ================================================================
   MATCH HISTORY / ROOM CARDS
   ================================================================ */
.match-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 107, 0, 0.2);
  border-radius: 14px;
  padding: 14px;
  margin-bottom: 10px;
}

.room-id-box {
  background: linear-gradient(
    135deg,
    rgba(255, 107, 0, 0.1),
    rgba(10, 10, 26, 0.8)
  );
  border: 1px solid rgba(255, 107, 0, 0.4);
  border-radius: 10px;
  padding: 10px 12px;
  margin-top: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.room-id-label {
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.5);
  font-family: "Rajdhani", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.room-id-value {
  font-family: "Orbitron", sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: white;
  letter-spacing: 0.05em;
}

/* ================================================================
   BLOCKED SCREEN
   ================================================================ */
.blocked-screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20px;
  background: #0a0a1a;
}

/* ================================================================
   FOOTER
   ================================================================ */
.footer-text {
  text-align: center;
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.25);
  padding: 16px;
  font-family: "Rajdhani", sans-serif;
}

.footer-text a {
  color: rgba(255, 107, 0, 0.6);
  text-decoration: none;
}

/* ================================================================
   NOTIFICATIONS
   ================================================================ */
.notif-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 107, 0, 0.15);
  border-radius: 12px;
  padding: 12px 14px;
  margin-bottom: 8px;
  transition: all 0.2s;
}

.notif-card.unread {
  border-color: rgba(255, 107, 0, 0.4);
  background: rgba(255, 107, 0, 0.06);
}

.notif-title {
  font-family: "Rajdhani", sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: white;
  margin-bottom: 3px;
}

.notif-msg {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.55);
  font-family: "Rajdhani", sans-serif;
}

.notif-time {
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.3);
  font-family: "Rajdhani", sans-serif;
  margin-top: 4px;
}

/* ================================================================
   TRANSACTION HISTORY
   ================================================================ */
.tx-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  font-family: "Rajdhani", sans-serif;
}

.tx-row:last-child {
  border-bottom: none;
}

.tx-type {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.6);
}

.tx-amount-pos {
  color: #00c864;
  font-weight: 600;
  font-size: 0.9rem;
}
.tx-amount-neg {
  color: #ef4444;
  font-weight: 600;
  font-size: 0.9rem;
}

/* ================================================================
   SCROLLBAR
   ================================================================ */
::-webkit-scrollbar {
  width: 4px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 107, 0, 0.3);
  border-radius: 2px;
}

/* ================================================================
   LIGHT MODE (optional)
   ================================================================ */
body.light-mode {
  --navy: #f0f0f8;
  background: #f0f0f8;
  color: #0a0a1a;
}

body.light-mode .app-container {
  background: #f0f0f8;
}

body.light-mode .auth-page {
  background: #f0f0f8;
}

body.light-mode .auth-form {
  background: rgba(0, 0, 0, 0.03);
  border-color: rgba(255, 107, 0, 0.3);
}

body.light-mode .fire-input {
  background: rgba(0, 0, 0, 0.05);
  color: #0a0a1a;
  border-color: rgba(255, 107, 0, 0.4);
}

body.light-mode .fire-input::placeholder {
  color: rgba(0, 0, 0, 0.35);
}

body.light-mode .card,
body.light-mode .mode-card {
  background: rgba(0, 0, 0, 0.03);
}

body.light-mode .app-header,
body.light-mode .bottom-nav {
  background: rgba(240, 240, 248, 0.95);
}

/* ================================================================
   EMPTY STATE
   ================================================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  text-align: center;
  opacity: 0.6;
}

.empty-state-icon {
  font-size: 3rem;
  margin-bottom: 12px;
}

.empty-state-text {
  font-family: "Rajdhani", sans-serif;
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.5);
}

/* ================================================================
   RULES COLLAPSIBLE
   ================================================================ */
.rules-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  padding: 4px 0;
}

.rules-list {
  list-style: none;
  padding: 0;
  margin: 10px 0 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.rules-list li {
  display: flex;
  gap: 8px;
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.65);
  font-family: "Rajdhani", sans-serif;
  line-height: 1.4;
}

.rules-num {
  color: #ff6b00;
  font-weight: 700;
  flex-shrink: 0;
  font-family: "Orbitron", sans-serif;
  font-size: 0.65rem;
  margin-top: 1px;
}

/* ================================================================
   COLOR PICKER
   ================================================================ */
.color-swatch {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 0.15s;
  flex-shrink: 0;
}

.color-swatch.selected {
  border-color: white;
  box-shadow: 0 0 0 2px rgba(255, 107, 0, 0.5);
  transform: scale(1.15);
}

/* ================================================================
   CHAT SUPPORT
   ================================================================ */
.chat-bubble {
  max-width: 80%;
  padding: 10px 14px;
  border-radius: 14px;
  font-family: "Rajdhani", sans-serif;
  font-size: 0.88rem;
  line-height: 1.4;
  margin-bottom: 8px;
}

.chat-bubble.sent {
  background: linear-gradient(
    135deg,
    rgba(255, 107, 0, 0.25),
    rgba(204, 85, 0, 0.2)
  );
  border: 1px solid rgba(255, 107, 0, 0.3);
  color: white;
  align-self: flex-end;
  margin-left: auto;
  border-bottom-right-radius: 4px;
}

.chat-bubble.received {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.9);
  align-self: flex-start;
  border-bottom-left-radius: 4px;
}

/* ================================================================
   ANNOUNCEMENT CARD
   ================================================================ */
.announcement-card {
  background: linear-gradient(
    135deg,
    rgba(255, 107, 0, 0.08),
    rgba(10, 10, 26, 0.6)
  );
  border: 1px solid rgba(255, 107, 0, 0.3);
  border-radius: 12px;
  padding: 12px 14px;
  margin-bottom: 8px;
}

.announcement-title {
  font-family: "Orbitron", sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  color: #ff6b00;
  margin-bottom: 4px;
}

.announcement-body {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.7);
  font-family: "Rajdhani", sans-serif;
  line-height: 1.4;
}
